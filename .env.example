SIDELAB_DEFAULT_BACKEND=deepseek

# DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# NVIDIA NIM
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_API_KEY=your_nvidia_api_key_here

# Kimi (Moonshot AI)
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_API_KEY=your_kimi_api_key_here

# Qwen (Alibaba DashScope)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
QWEN_API_KEY=your_qwen_api_key_here

# Zhipu AI (GLM-4)
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4-flash
ZHIPU_API_KEY=your_zhipu_api_key_here

# Yi (01.AI)
YI_BASE_URL=https://api.lingyiwanwu.com/v1
YI_MODEL=yi-lightning
YI_API_KEY=your_yi_api_key_here

# Baichuan AI
BAICHUAN_BASE_URL=https://api.baichuan-ai.com/v1
BAICHUAN_MODEL=Baichuan4
BAICHUAN_API_KEY=your_baichuan_api_key_here

# Baidu ERNIE (Qianfan)
ERNIE_BASE_URL=https://qianfan.baidubce.com/v2
ERNIE_MODEL=ernie-4.0-8k
ERNIE_API_KEY=your_ernie_api_key_here

# iFlytek Spark
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_MODEL=generalv3.5
SPARK_API_KEY=your_spark_api_key_here

# Google Gemini (Vertex AI — uses Application Default Credentials)
VERTEX_PROJECT=your_gcp_project_id_here
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash-001

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
